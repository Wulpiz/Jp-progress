<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Japanese Focus - Hardcore Mode</title>
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  <style>
    :root {
      --bg-dark: #020617;
      --card-bg: #1e293b;
      --accent-blue: #3b82f6;
      --accent-cyan: #2dd4bf;
      --accent-red: #ef4444;
      --text-main: #f8fafc;
      --text-dim: #94a3b8;
      --glass: rgba(255, 255, 255, 0.03);
      --glass-border: rgba(255, 255, 255, 0.08);
    }

    * { box-sizing: border-box; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); }

    body {
      margin: 0; min-height: 100vh;
      background: radial-gradient(circle at 50% 50%, #0f172a 0%, #020617 100%);
      color: var(--text-main);
      font-family: 'Inter', system-ui, sans-serif;
      display: flex; align-items: center; justify-content: center; padding: 20px;
    }

    /* --- EFEK SHINING ANIMASI UNTUK JUDUL --- */
    .hero-title {
      font-size: 4.5rem;
      font-weight: 900;
      margin: 0;
      letter-spacing: -3px;
      position: relative;
      display: inline-block;
      background: linear-gradient(
        to right, 
        #ffffff 20%, 
        #3b82f6 40%, 
        #2dd4bf 60%, 
        #ffffff 80%
      );
      background-size: 200% auto;
      color: #000;
      background-clip: text;
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      animation: shine 3s linear infinite;
    }

    @keyframes shine {
      to { background-position: 200% center; }
    }

    #auth-screen { 
      background: var(--glass); 
      backdrop-filter: blur(30px); 
      padding: 60px 40px; 
      border-radius: 40px; 
      border: 1px solid var(--glass-border); 
      text-align: center; 
      max-width: 500px; 
      width: 100%; 
    }

    .container { 
      display: none; 
      width: 100%; 
      max-width: 900px; 
      background: var(--glass); 
      border: 1px solid var(--glass-border); 
      border-radius: 32px; 
      padding: 40px; 
      backdrop-filter: blur(25px); 
      position: relative; 
    }

    .hero-section { text-align: center; margin-bottom: 40px; }
    .hero-subtitle { color: var(--accent-blue); font-weight: 600; margin-top: 10px; font-size: 1.1rem; }

    .header-info { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 30px; }
    .stat-card { background: rgba(0,0,0,0.2); padding: 20px; border-radius: 20px; border: 1px solid var(--glass-border); text-align: center; }
    .stat-label { font-size: 0.7rem; text-transform: uppercase; color: var(--text-dim); letter-spacing: 1px; }
    .stat-value { font-size: 1.8rem; font-weight: 800; color: var(--accent-blue); }
    .timer-critical { color: var(--accent-red) !important; animation: blink 1s infinite; }

    /* Class Dinamis untuk Streak */
    .streak-zero { color: var(--text-dim) !important; filter: grayscale(100%); opacity: 0.6; }
    .streak-active { color: #facc15 !important; filter: grayscale(0%); opacity: 1; }

    /* Progress Track */
    .progress-box { background: rgba(255,255,255,0.02); padding: 15px; border-radius: 15px; border: 1px solid var(--glass-border); margin-bottom: 10px; }
    .progress-label { display: flex; justify-content: space-between; font-size: 0.7rem; font-weight: 800; color: var(--text-dim); text-transform: uppercase; margin-bottom: 8px; }
    .progress-track { height: 6px; background: rgba(255,255,255,0.05); border-radius: 10px; overflow: hidden; }
    .progress-fill { height: 100%; width: 0%; background: linear-gradient(90deg, var(--accent-blue), var(--accent-cyan)); transition: width 0.6s cubic-bezier(0.34, 1.56, 0.64, 1); }

    h2 { border-left: 4px solid var(--accent-blue); padding-left: 15px; margin: 40px 0 20px; font-size: 1.2rem; text-transform: uppercase; letter-spacing: 1px; }

    .quest-item {
      background: rgba(255,255,255,0.02); padding: 18px; border-radius: 15px;
      margin-bottom: 12px; border: 1px solid var(--glass-border);
      display: flex; align-items: center; gap: 15px;
    }
    .quest-item:hover { background: rgba(255,255,255,0.05); }
    .checkbox { width: 22px; height: 22px; cursor: pointer; accent-color: var(--accent-blue); flex-shrink: 0; }
    .goal-info { flex: 1; min-width: 0; } /* min-width mencegah text panjang merusak layout */
    .quest-text { font-size: 1.05rem; font-weight: 500; word-wrap: break-word; word-break: break-word; }
    .completed { opacity: 0.3; text-decoration: line-through; color: var(--accent-cyan); }
    .goal-deadline { font-size: 0.8rem; color: var(--text-dim); margin-top: 4px; }

    .add-placeholder { background: rgba(255,255,255,0.01); border: 1px dashed var(--glass-border); color: var(--text-dim); width: 100%; padding: 16px; border-radius: 15px; cursor: pointer; margin-top: 5px; font-weight: 600; text-align: center; }
    .add-placeholder:hover { border-color: var(--accent-blue); color: var(--accent-blue); background: rgba(59, 130, 246, 0.03); }

    .btn-delete { background: none; border: none; cursor: pointer; opacity: 0.3; font-size: 1.1rem; flex-shrink: 0; }
    .btn-delete:hover { opacity: 1; transform: scale(1.1); color: var(--accent-red); }

    /* Modal */
    #goal-modal {
      display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%;
      background: rgba(2, 6, 23, 0.7); backdrop-filter: blur(15px);
      z-index: 1000; align-items: center; justify-content: center; padding: 20px;
    }
    .modal-content { background: #0f172a; border: 1px solid var(--glass-border); padding: 40px; border-radius: 30px; width: 90%; max-width: 400px; text-align: center; }
    .modal-content input { width: 100%; padding: 15px; margin: 20px 0; border-radius: 12px; border: 1px solid var(--glass-border); background: rgba(0,0,0,0.3); color: white; outline: none; font-size: 1rem; }
    .modal-actions { display: flex; gap: 10px; }
    .btn-modal { flex: 1; padding: 12px; border-radius: 12px; border: none; font-weight: 700; cursor: pointer; }
    .btn-confirm { background: var(--accent-blue); color: white; }
    .btn-cancel { background: rgba(255,255,255,0.05); color: var(--text-dim); border: 1px solid var(--glass-border); }

    @keyframes blink { 50% { opacity: 0.5; } }
    .google-btn { background: white; color: #020617; padding: 15px 30px; border-radius: 15px; font-weight: 800; border: none; cursor: pointer; display: flex; align-items: center; gap: 10px; margin: 0 auto; }

    /* ==========================================================================
       OPTIMASI RESPONSIVITAS HP (MEDIA QUERIES)
       ========================================================================== */
    @media (max-width: 768px) {
      body {
        padding: 12px;
      }

      .hero-title {
        font-size: 2.8rem; /* Mengecilkan judul di HP agar tidak patah berantakan */
        letter-spacing: -1.5px;
      }

      .hero-subtitle {
        font-size: 0.95rem;
        padding: 0 10px;
      }

      #auth-screen {
        padding: 40px 20px;
        border-radius: 24px;
      }

      .container {
        padding: 20px 16px; /* Mengurangi padding box utama agar konten lebih luas */
        border-radius: 24px;
      }

      .header-info {
        grid-template-columns: 1fr; /* Stat Card diubah jadi susunan atas-bawah di HP */
        gap: 12px;
        margin-bottom: 20px;
      }

      .stat-card {
        padding: 15px;
        border-radius: 16px;
      }

      .stat-value {
        font-size: 1.5rem;
      }

      h2 {
        margin: 30px 0 15px;
        font-size: 1.05rem;
      }

      .quest-item {
        padding: 14px;
        gap: 12px;
        border-radius: 12px;
      }

      .quest-text {
        font-size: 0.95rem; /* Ukuran font teks goal disesuaikan untuk HP */
      }

      .add-placeholder {
        padding: 14px;
        font-size: 0.9rem;
        border-radius: 12px;
      }

      .modal-content {
        padding: 25px 20px;
        border-radius: 20px;
      }

      /* Baris penunjuk sisa bulan dibuat flex vertikal tipis di HP */
      .container > .stat-card[style*="display: flex"] {
        flex-direction: column !important;
        gap: 6px;
        text-align: center;
        align-items: center !important;
      }
      .container > .stat-card[style*="display: flex"] span {
        text-align: center !important;
      }
    }

    @media (max-width: 360px) {
      /* Optimasi khusus untuk HP dengan layar ekstra kecil (seperti iPhone SE lama) */
      .hero-title {
        font-size: 2.2rem;
      }
      .stat-value {
        font-size: 1.3rem;
      }
    }
  </style>
</head>
<body>

  <div id="goal-modal">
    <div class="modal-content">
      <h3 id="modal-title">Tambah Goal</h3>
      <input type="text" id="modal-text" placeholder="Masukkan nama goal..." onkeydown="if(event.key==='Enter') submitModal()">
      <div class="modal-actions">
        <button class="btn-modal btn-cancel" onclick="closeModal()">Batal</button>
        <button class="btn-modal btn-confirm" id="btn-submit-goal" onclick="submitModal()">Tambahkan</button>
      </div>
    </div>
  </div>

  <div id="auth-screen">
    <h1 class="hero-title">まず日本語。</h1>
    <p style="color: var(--accent-blue); margin-bottom:30px;">Daily Quest: Win or Lose Everything.</p>
    <button class="google-btn" onclick="loginWithGoogle()">
      <img src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg" width="18"> Masuk dengan Google
    </button>
  </div>

  <div class="container" id="main-dashboard">
    <div class="hero-section">
      <h1 class="hero-title">まず日本語。</h1>
      <p class="hero-subtitle">Lakukanlah sekarang dan paksa diri sendiri, jadikan itu sebagai kebiasaan</p>
    </div>

    <div class="header-info">
      <div class="stat-card">
        <div class="stat-label">Daily Reset In</div>
        <div class="stat-value" id="dailyTimer">00:00:00</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Current Streak</div>
        <div class="stat-value" id="streakVal">🔥 0 Hari</div>
      </div>
    </div>

    <h2>⚔️ Daily Quests</h2>
    <div class="progress-box">
      <div class="progress-label"><span>Daily Progress</span><span id="dailyPercent">0%</span></div>
      <div class="progress-track"><div class="progress-fill" id="dailyFill"></div></div>
    </div>
    <div id="dailyQuestsList"></div>
    <button onclick="openModal('daily')" class="add-placeholder">+ Tambah Goal Harian</button>

    <h2>🏆 Monthly Epic Goals</h2>
    <div class="progress-box">
      <div class="progress-label"><span>Monthly Progress</span><span id="monthlyPercent">0%</span></div>
      <div class="progress-track"><div class="progress-fill" id="monthlyFill"></div></div>
    </div>
    <div class="stat-card" style="margin-bottom: 20px; display: flex; justify-content: space-between; align-items: center; padding: 15px 25px;">
        <span class="stat-label" style="text-align: left;">Bulan Ini Berakhir Dalam:</span>
        <span id="monthlyTimer" style="font-weight: 700; color: var(--accent-cyan); font-size: 1.1rem;">00 Hari</span>
    </div>
    <div id="monthlyGoalsList"></div>
    <button onclick="openModal('monthly')" class="add-placeholder">+ Tambah Goal Bulanan</button>

    <button onclick="logout()" style="background:none; border:none; color:var(--text-dim); cursor:pointer; text-decoration: underline; font-size: 0.8rem; width:100%; margin-top:40px;">Logout Akun</button>
  </div>

  <script>
    const SB_URL = 'https://ifdgmtzdgyldobeparjy.supabase.co';
    const SB_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImlmZGdtdHpkZ3lsZG9iZXBhcmp5Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzg2ODY2MTIsImV4cCI6MjA5NDI2MjYxMn0.xJqjlPNZgU3vYHhuv1IF6ph4UvsJR7oSFYM8pVByVmw';
    const clientApp = supabase.createClient(SB_URL, SB_KEY);

    let currentUser = null;
    let allGoals = [];
    let dbStreak = 0;
    let currentModalType = 'daily';

    async function checkUser() {
      const { data: { user } } = await clientApp.auth.getUser();
      if (user) {
        currentUser = user;
        document.getElementById('auth-screen').style.display = 'none';
        document.getElementById('main-dashboard').style.display = 'block';
        await fetchOrCreateProfile();
        fetchData();
        startTimers();
      }
    }

    // Ambil atau buat profil streak di database cloud
    async function fetchOrCreateProfile() {
      let { data: profile, error } = await clientApp.from('user_profiles').select('streak').eq('user_id', currentUser.id).single();
      
      if (error && error.code === 'PGRST116') { // Jika profil belum ada di DB
        const { data: newProfile } = await clientApp.from('user_profiles').insert([{ user_id: currentUser.id, streak: 0 }]).select().single();
        dbStreak = newProfile ? newProfile.streak : 0;
      } else if (profile) {
        dbStreak = profile.streak;
      }
    }

    async function fetchData() {
      const { data } = await clientApp.from('goals').select('*').eq('user_id', currentUser.id).order('created_at', { ascending: true });
      allGoals = data || [];
      render();
    }

    function openModal(type) {
      currentModalType = type;
      document.getElementById('modal-title').innerText = type === 'daily' ? 'Tambah Goal Harian' : 'Tambah Goal Bulanan';
      document.getElementById('goal-modal').style.display = 'flex';
      setTimeout(() => document.getElementById('modal-text').focus(), 100);
    }

    function closeModal() {
      document.getElementById('goal-modal').style.display = 'none';
      document.getElementById('modal-text').value = '';
    }

    async function submitModal() {
      const text = document.getElementById('modal-text').value.trim();
      if(!text) return;

      const btn = document.getElementById('btn-submit-goal');
      btn.innerText = "Menyimpan...";
      btn.disabled = true;

      const { data, error } = await clientApp.from('goals').insert([{ 
        text: text, 
        user_id: currentUser.id, 
        type: currentModalType, 
        checked: false,
        deadline: currentModalType === 'daily' ? 'Daily Reset' : 'End of Month'
      }]).select();

      btn.innerText = "Tambahkan";
      btn.disabled = false;

      if(!error) {
        allGoals.push(data[0]);
        closeModal();
        render();
      } else {
        alert("Gagal menyimpan: " + error.message);
      }
    }

    async function toggleGoal(id, status) {
      await clientApp.from('goals').update({ checked: !status }).eq('id', id);
      fetchData();
    }

    async function deleteGoal(id, text) {
      if (confirm(`Apakah kamu yakin ingin menghapus goal: "${text}"?`)) {
        const { error } = await clientApp.from('goals').delete().eq('id', id);
        if(!error) {
            fetchData();
        } else {
            alert("Gagal menghapus data.");
        }
      }
    }

    function render() {
      const dList = document.getElementById("dailyQuestsList");
      const mList = document.getElementById("monthlyGoalsList");
      dList.innerHTML = ""; mList.innerHTML = "";

      allGoals.forEach((g) => {
        const item = `
          <div class="quest-item" ${g.type === 'monthly' ? 'style="border-left: 3px solid var(--accent-cyan)"' : ''}>
            <input type="checkbox" class="checkbox" ${g.checked ? 'checked' : ''} onchange="toggleGoal('${g.id}', ${g.checked})">
            <div class="goal-info">
              <span class="quest-text ${g.checked ? 'completed' : ''}">${escapeHtml(g.text)}</span>
              <div class="goal-deadline">${g.type === 'daily' ? '⌛ Daily Reset' : '🗓️ End of Month'}</div>
            </div>
            <button class="btn-delete" onclick="deleteGoal('${g.id}', '${escapeHtml(g.text)}')">🗑️</button>
          </div>
        `;
        if(g.type === 'monthly') mList.innerHTML += item;
        else dList.innerHTML += item;
      });
      updateProgress();
    }

    function updateProgress() {
      const dailyGoals = allGoals.filter(g => g.type === 'daily');
      const dailyDone = dailyGoals.filter(g => g.checked).length;
      const dailyPercent = dailyGoals.length === 0 ? 0 : Math.round((dailyDone / dailyGoals.length) * 100);
      document.getElementById("dailyFill").style.width = dailyPercent + "%";
      document.getElementById("dailyPercent").innerText = dailyPercent + "%";

      const monthlyGoals = allGoals.filter(g => g.type === 'monthly');
      const monthlyDone = monthlyGoals.filter(g => g.checked).length;
      const monthlyPercent = monthlyGoals.length === 0 ? 0 : Math.round((monthlyDone / monthlyGoals.length) * 100);
      document.getElementById("monthlyFill").style.width = monthlyPercent + "%";
      document.getElementById("monthlyPercent").innerText = monthlyPercent + "%";
      
      // LOGIK CLOUD STREAK BARU
      const streakEl = document.getElementById("streakVal");
      streakEl.innerText = `🔥 ${dbStreak} Hari`;
      
      if (dbStreak === 0) {
        streakEl.className = "stat-value streak-zero";
      } else {
        streakEl.className = "stat-value streak-active";
      }
    }

    function startTimers() {
      setInterval(() => {
        const now = new Date();
        const midnight = new Date().setHours(24, 0, 0, 0);
        const diff = midnight - now;
        const h = Math.floor(diff / 3600000).toString().padStart(2, '0');
        const m = Math.floor((diff % 3600000) / 60000).toString().padStart(2, '0');
        const s = Math.floor((diff % 60000) / 1000).toString().padStart(2, '0');
        
        const timerEl = document.getElementById("dailyTimer");
        timerEl.innerText = `${h}:${m}:${s}`;
        
        // Pemicu tampilan lokal saat jam 00:00:00
        if (h === "00" && m === "00" && s === "00") {
            dbStreak = 0;
            updateProgress();
        }

        if (diff < 3600000) timerEl.classList.add('timer-critical');

        const endOfMonth = new Date(now.getFullYear(), now.getMonth() + 1, 0);
        const mDiff = endOfMonth - now;
        const daysLeft = Math.floor(mDiff / (1000 * 60 * 60 * 24));
        const mEl = document.getElementById("monthlyTimer");
        mEl.innerText = daysLeft > 0 ? `${daysLeft} Hari lagi` : `${h}:${m}:${s}`;
      }, 1000);
    }

    function escapeHtml(text) {
      const div = document.createElement('div');
      div.innerText = text;
      return div.innerHTML;
    }

    async function loginWithGoogle() { await clientApp.auth.signInWithOAuth({ provider: 'google', options: { redirectTo: window.location.href } }); }
    async function logout() { await clientApp.auth.signOut(); location.reload(); }
    checkUser();
  </script>
</body>
</html>
